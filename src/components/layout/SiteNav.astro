---
import type { NavBarLink } from "../../types/config";

interface Props {
	links: NavBarLink[];
	pathname: string;
}

const { links, pathname } = Astro.props;
---

<header class="site-nav-wrap px-4">
	<div class="mx-auto w-full max-w-lg">
		<nav class="site-nav flex items-center justify-center !rounded-full !bg-[rgba(243,244,245,0.4)] !backdrop-blur-md border border-[#d0d0d0]/40 overflow-hidden" aria-label="Main navigation">
			<div class="site-nav-links flex w-full gap-4 sm:gap-6 px-4 py-2 overflow-x-auto snap-x snap-mandatory scrollbar-hide">
				{links.map((link) => (
					<a
						href={link.url}
						target={link.external ? "_blank" : undefined}
						rel="noreferrer"
						aria-current={pathname === link.url ? "page" : undefined}
						class:list={[
							"text-[0.65rem] whitespace-nowrap snap-center uppercase tracking-[0.3em] sm:tracking-[0.4em] transition-colors duration-200 hover:text-primary",
							{ "text-primary font-bold": pathname === link.url },
							{ "text-[#8a8a8a] font-medium": pathname !== link.url },
						]}
					>
						[{link.title}]
					</a>
				))}
			</div>
		</nav>
	</div>
</header>
