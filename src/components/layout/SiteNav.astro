---
import type { NavBarLink } from "../../types/config";

interface Props {
	links: NavBarLink[];
	pathname: string;
}

const { links, pathname } = Astro.props;
---

<header class="site-nav-wrap">
	<div class="shell">
		<nav class="site-nav" aria-label="Main navigation">
			<a href="/" class="site-nav-mark" aria-label="Vishal Sharma home">
				<span class="site-nav-mark__glyph" aria-hidden="true"></span>
				<span>VS</span>
			</a>

			<div class="site-nav-links">
				{links.map((link) => (
					<a
						href={link.url}
						target={link.external ? "_blank" : undefined}
						rel="noreferrer"
						aria-current={pathname === link.url ? "page" : undefined}
						class:list={[
							"site-nav-link",
							{ "is-active": pathname === link.url },
						]}
					>
						{link.title}
					</a>
				))}
			</div>
		</nav>
	</div>
</header>
