---
import { identity, navBarLinks, socialLinks } from "../config";
import type { SEOInfo } from "../types/config";
import "../styles/globals.css";
import SiteNav from "../components/layout/SiteNav.astro";

interface Props {
	seo: SEOInfo;
}

const { seo } = Astro.props;
const pathname = Astro.url.pathname;
---

<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{seo.title}</title>
		<meta name="description" content={seo.description} />
		<meta property="og:title" content={seo.title} />
		<meta property="og:description" content={seo.description} />
		<meta property="og:image" content={seo.image} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={seo.title} />
		<meta name="twitter:description" content={seo.description} />
	</head>
	<body>
		<div class="site-backdrop" aria-hidden="true">
			<div class="site-grid"></div>
			<div class="site-glow site-glow-a"></div>
			<div class="site-glow site-glow-b"></div>
			<div class="site-glow site-glow-c"></div>
			<div class="site-glow site-glow-d"></div>
		</div>

		<SiteNav links={navBarLinks} pathname={pathname} />

		<main class="site-main">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="shell">
				<div class="footer-gradient-bar"></div>
				<div class="footer-panel">
					<div>
						<p class="footer-kicker">Vishal Sharma</p>
						<h2 class="footer-title">{identity.role}</h2>
					</div>
					<div class="footer-meta">
						<p>{identity.location}</p>
						<p>
							<a href={`mailto:${identity.email}`}>{identity.email}</a>
						</p>
					</div>
					<div class="footer-links">
						{socialLinks.map((link) => (
							<a href={link.url} target={link.external ? "_blank" : undefined} rel="noreferrer">
								{link.title}
							</a>
						))}
					</div>
				</div>
			</div>
		</footer>

		<!-- Scroll reveal: IntersectionObserver for .reveal-on-scroll elements -->
		<script>
			(function () {
				if (typeof IntersectionObserver === "undefined") return;
				const observer = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								observer.unobserve(entry.target);
							}
						}
					},
					{ threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
				);
				const targets = document.querySelectorAll(".reveal-on-scroll");
				for (const el of targets) observer.observe(el);
			})();
		</script>
	</body>
</html>
