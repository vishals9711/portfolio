---
import SignalDivider from "../components/graphics/SignalDivider.astro";
import { aboutPageContent, socialLinks } from "../config";
import Layout from "../layouts/Layout.astro";
---

<Layout seo={aboutPageContent.seo}>
	<!-- ═══ PAGE HERO ══════════════════════════════════════════ -->
	<section class="shell page-hero">
		<p class="eyebrow">{aboutPageContent.eyebrow}</p>
		<h1 class="page-title">{aboutPageContent.headline}</h1>
		<p class="page-description">{aboutPageContent.intro}</p>
	</section>

	<!-- ═══ EDITORIAL GRID ════════════════════════════════════ -->
	<section class="shell editorial-grid">
		<div class="reveal-on-scroll">
			<SignalDivider label="Path" animate={true} />
			<div class="story-block">
				{aboutPageContent.story.map((paragraph) => (
					<p>{paragraph}</p>
				))}
			</div>
		</div>
		<aside class="note-panel reveal-on-scroll">
			<p class="note-panel__label">Operating mode</p>
			<ul>
				{aboutPageContent.approach.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		</aside>
	</section>

	<!-- ═══ TIMELINE ══════════════════════════════════════════ -->
	<section class="shell timeline-section">
		<SignalDivider label="Timeline" animate={true} />
		<div class="timeline-track">
			{aboutPageContent.timeline.map((item) => (
				<article class="timeline-item reveal-on-scroll">
					<span class="timeline-item__node" aria-hidden="true"></span>
					<div class="timeline-item__meta">
						<p>{item.label}</p>
						<span>{item.period}</span>
					</div>
					<div>
						<h2>{item.title}</h2>
						<p>{item.description}</p>
					</div>
				</article>
			))}
		</div>
	</section>

	<!-- ═══ INTERESTS ═════════════════════════════════════════ -->
	<section class="shell interest-section">
		<SignalDivider label="Interests" animate={true} />
		<div class="interest-grid">
			{aboutPageContent.interests.map((item) => (
				<article class="interest-card reveal-on-scroll">
					<h2>{item.title}</h2>
					<p>{item.description}</p>
				</article>
			))}
		</div>
	</section>

	<!-- ═══ CTA ════════════════════════════════════════════════ -->
	<section class="shell cta-panel reveal-on-scroll">
		<div>
			<p class="eyebrow">Connect</p>
			<h2 class="section-title">{aboutPageContent.connectTitle}</h2>
		</div>
		<div class="connect-list">
			<p>{aboutPageContent.connectDescription}</p>
			<div class="connect-list__links">
				{socialLinks.map((link) => (
					<a href={link.url} target={link.external ? "_blank" : undefined} rel="noreferrer" class="connect-link">
						<img src={link.icon} alt="" aria-hidden="true" />
						<div>
							<span>{link.title}</span>
							<small>{link.label}</small>
						</div>
					</a>
				))}
			</div>
		</div>
	</section>
</Layout>
